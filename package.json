    "uninstall-hook": "node bin/uninstall.js",
    "dashboard": "node bin/dashboard.js",
    "test": "node src/index.js --dry-run"
  },
  "keywords": [
    "react",
    "react-native",
    "code-review",
    "git-hook",
    "ai",
    "security"
  ],
