  "description": "Self-improving AI code reviewer that thinks like a senior dev. Catches crashes, ANRs, security holes, perf issues, and bad patterns before they hit production.",
  "main": "src/index.js",
  "bin": {
    "ai-reviewer": "bin/cli.js"
  },
  "scripts": {
    "review": "node src/index.js",
